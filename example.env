# OpsPilot Environment Variables Example
# Copy this file to .env and fill in the values

# --- Authentication ---
# Secret key for signing JWT tokens
JWT_SECRET=your-super-secret-jwt-key

# --- Database ---
# HA PostgreSQL connection details
DB_HOST=192.168.25.26
DB_USER=postgres
DB_PASS=postgres
DB_NAME=opspilot
DB_PORT=5432

# --- Infrastructure (Proxmox) ---
# API Token for Terraform provider to interact with Proxmox
PM_API_TOKEN_ID=user@pve!token-name
PM_API_TOKEN_SECRET=your-proxmox-api-token-secret

# --- Deployment & CI/CD ---
# SSH credentials for deploying to dynamic VMs
SSH_USER=root
SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"

# Git repository URL for the project being deployed
PROJECT_REPO_URL=https://github.com/your-org/your-app.git

# Container Registry details for storing built images
REGISTRY_URL=localhost:5000
REGISTRY_USER=admin
REGISTRY_PASS=registry-password

# --- Observability ---
# URL for VictoriaMetrics (or Prometheus) to store time-series metrics
VICTORIAMETRICS_URL=http://localhost:8428/api/v1/write

# --- External Tools (Optional/Planned) ---
# VAULT_ADDR=http://127.0.0.1:8200
# ENVIRONMENT=production
